{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto Pull .env from Railway",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/pull_railway_env.ps1",
        "-OutFile",
        ".env"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
