FROM golang:1.24-bookworm AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/workflow-drive-csv-consolidation ./cmd/workflow-drive-csv-consolidation

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    poppler-utils \
    imagemagick \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /out/workflow-drive-csv-consolidation /app/workflow-drive-csv-consolidation

CMD ["/app/workflow-drive-csv-consolidation"]
