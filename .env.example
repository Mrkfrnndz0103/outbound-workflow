PORT=8080

# Modes:
# - bot: callback-driven bot commands/events
# - system_account: outbound-only group messaging via system account webhook
SEATALK_MODE=bot

# Bot mode config (SEATALK_MODE=bot)
SEATALK_SIGNING_SECRET=
SEATALK_APP_ID=
SEATALK_APP_SECRET=
SEATALK_BASE_URL=https://openapi.seatalk.io

# System account mode config (SEATALK_MODE=system_account)
SEATALK_SYSTEM_WEBHOOK_URL=

SEATALK_HTTP_TIMEOUT_SECONDS=10

BOT_COMMAND_PREFIX=/
WORKFLOWS_FILE=workflows.yaml
WORKFLOW_DEFAULT_TIMEOUT_SECONDS=120

# Workflow 1 (MM LH Provided -> SeaTalk trigger)
WF1_GOOGLE_CREDENTIALS_FILE=
# Alternative to credentials file (full JSON string)
WF1_GOOGLE_CREDENTIALS_JSON=
# WF1_SHEET_ID defaults to 1mhzIfYfF1VSA9sPiqnLw7OgY1S_gI0wEzkXBQ1CCuDg
WF1_SHEET_ID=
# WF1_SHEET_TAB defaults to "MM LH Provided"
WF1_SHEET_TAB=
# WF1_SHEET_RANGE defaults to "A2:M"
WF1_SHEET_RANGE=
# SeaTalk send mode for WF1: "webhook" or "bot"
WF1_SEATALK_MODE=webhook
# Required when WF1_SEATALK_MODE=bot (fallback order: WF1_* -> WF2_* -> global SEATALK_*)
WF1_SEATALK_GROUP_ID=
WF1_SEATALK_APP_ID=
WF1_SEATALK_APP_SECRET=
WF1_SEATALK_BASE_URL=https://openapi.seatalk.io
# Required when WF1_SEATALK_MODE=webhook (fallback to SEATALK_SYSTEM_WEBHOOK_URL)
WF1_SEATALK_WEBHOOK_URL=
# State file that stores last seen Plate # per row
WF1_STATE_FILE=data/workflow1-mm-lh-provided-state.json
# Runtime status output file (set to "none" to disable)
WF1_STATUS_FILE=data/workflow1-mm-lh-provided-status.json
# false = first run baselines current rows and does not send existing non-blank Plate # rows
WF1_BOOTSTRAP_SEND_EXISTING=false
WF1_AT_ALL=false
WF1_DRY_RUN=false
WF1_DEBUG_LOG_SKIPS=false
WF1_HTTP_TIMEOUT_SECONDS=10
WF1_CONTINUOUS=false
WF1_POLL_INTERVAL_SECONDS=1
WF1_FORCE_SEND_AFTER_SECONDS=60
# Skip stale ready rows older than this age (seconds). Helps avoid replay after webhook downtime.
WF1_MAX_READY_AGE_SECONDS=300
# Kept for compatibility; WF1 send trigger now uses F/H/I readiness + force-after fallback.
WF1_PROVIDE_TIME_MIN_AGE_SECONDS=0
# Hold a ready row briefly to allow same-minute Provide Time rows to merge
WF1_GROUP_DEFER_SECONDS=20
# Outbound throttle/retry to avoid SeaTalk rate limits (429 code=8)
WF1_SEND_MIN_INTERVAL_MS=1200
WF1_SEND_RETRY_MAX_ATTEMPTS=5
WF1_SEND_RETRY_BASE_MS=1000
WF1_SEND_RETRY_MAX_MS=30000
# Optional health server + self-ping (useful on Render web services)
WF1_ENABLE_HEALTH_SERVER=false
WF1_HEALTH_PORT=
WF1_SELF_PING_URL=
WF1_SELF_PING_INTERVAL_SECONDS=300

# Workflow 2 (Backlogs Summary snapshot -> SeaTalk group via bot)
WF2_GOOGLE_CREDENTIALS_FILE=
# Alternative to credentials file (full JSON string)
WF2_GOOGLE_CREDENTIALS_JSON=
WF2_SHEET_ID=17cvCc6ffMXNs6JYnpMYvDO_V8nBCRKRm3G78oINj_yo
WF2_SHEET_TAB=Backlogs Summary
WF2_CAPTURE_RANGE=C2:S64
WF2_TRIGGER_CELL=G4
# Required target group chat ID (bot must be a member)
WF2_SEATALK_GROUP_ID=
# Optional overrides; defaults to SEATALK_APP_ID / SEATALK_APP_SECRET
WF2_SEATALK_APP_ID=
WF2_SEATALK_APP_SECRET=
WF2_STATE_FILE=data/workflow2-ob-pending-dispatch-state.json
WF2_STATUS_FILE=data/workflow2-ob-pending-dispatch-status.json
WF2_BOOTSTRAP_SEND_EXISTING=false
WF2_DRY_RUN=false
WF2_CONTINUOUS=true
WF2_POLL_INTERVAL_SECONDS=10
WF2_HTTP_TIMEOUT_SECONDS=10
WF2_TIMEZONE=Asia/Manila
WF2_IMAGE_MAX_WIDTH_PX=3000
WF2_IMAGE_MAX_BASE64_BYTES=5242880
# 1-4, higher = clearer/larger image (default 2)
WF2_RENDER_SCALE=2
# Number of checks before send (>=2). Must stay unchanged between checks.
WF2_STABILITY_RUNS=3
# Seconds between stability checks.
WF2_STABILITY_WAIT_SECONDS=2
WF2_ENABLE_HEALTH_SERVER=true
WF2_HEALTH_PORT=

# Workflow 2.1 (Drive ZIP -> consolidated CSV in R2 -> filtered import to Google Sheet)
WF21_GOOGLE_CREDENTIALS_FILE=
# Alternative to credentials file (full JSON string)
WF21_GOOGLE_CREDENTIALS_JSON=
WF21_DRIVE_PARENT_FOLDER_ID=1oU9kj5VIJIoNrR388wYCHSdtHGanRrgZ
WF21_DESTINATION_SHEET_ID=1mdi-8ACluDHGZ7yAyNLwXLwpmQ4f6VAx3kpbaJORViA
WF21_DESTINATION_TAB_PENDING_RCV=pending_rcv
WF21_DESTINATION_TAB_PACKED_IN_ANOTHER_TO=packed_in_another_to
WF21_DESTINATION_TAB_NO_LHPACKING=no_lhpacking
WF21_R2_ACCOUNT_ID=
WF21_R2_BUCKET=
WF21_R2_ACCESS_KEY_ID=
WF21_R2_SECRET_ACCESS_KEY=
WF21_R2_OBJECT_PREFIX=wf2-1
WF21_STATE_FILE=data/workflow2-1-drive-csv-consolidation-state.json
WF21_STATUS_FILE=data/workflow2-1-drive-csv-consolidation-status.json
WF21_BOOTSTRAP_PROCESS_EXISTING=true
WF21_DROP_LEADING_UNNAMED_COLUMN=true
WF21_DRY_RUN=false
WF21_CONTINUOUS=true
WF21_ENABLE_HEALTH_SERVER=true
WF21_HEALTH_PORT=
WF21_POLL_INTERVAL_SECONDS=30
WF21_SHEETS_BATCH_SIZE=7000
# Retry tuning for Google Sheets write throttling (429/5xx/transient network errors)
WF21_SHEETS_WRITE_RETRY_MAX_ATTEMPTS=6
WF21_SHEETS_WRITE_RETRY_BASE_MS=1000
WF21_SHEETS_WRITE_RETRY_MAX_MS=15000
WF21_TEMP_DIR=
# Post-import summary snapshot -> SeaTalk (bot/webhook) image
WF21_SUMMARY_SEND_ENABLED=true
WF21_SUMMARY_SEATALK_MODE=bot
# SeaTalk bot API credentials/group for summary send
# Fallback order: WF21_* -> WF2_* -> global SEATALK_*
WF21_SEATALK_APP_ID=
WF21_SEATALK_APP_SECRET=
WF21_SEATALK_BASE_URL=https://openapi.seatalk.io
WF21_SEATALK_GROUP_ID=
# SeaTalk system-account webhook URL (used when WF21_SUMMARY_SEATALK_MODE=webhook)
# Fallback to SEATALK_SYSTEM_WEBHOOK_URL when empty
WF21_SEATALK_WEBHOOK_URL=
WF21_SUMMARY_SHEET_ID=
WF21_SUMMARY_TAB=[SOC] Backlogs Summary
WF21_SUMMARY_RANGE=B2:Q59
WF21_SUMMARY_SECOND_IMAGE_ENABLED=false
WF21_SUMMARY_SECOND_TAB=[SOC5] SOCPacked_Dashboard
WF21_SUMMARY_SECOND_RANGES=A1:U9,B142:T167
# Helper cell updated after import sync; summary send starts after this value changes.
WF21_SUMMARY_SYNC_CELL=config!B1
# Wait after import before capture/send (seconds)
WF21_SUMMARY_WAIT_SECONDS=8
# Snapshot stabilization checks before capture/send
WF21_SUMMARY_STABILITY_RUNS=3
WF21_SUMMARY_STABILITY_WAIT_SECONDS=2
# styled = current in-code renderer, pdf_png = Google Sheets PDF export then convert first page to PNG
WF21_SUMMARY_RENDER_MODE=styled
WF21_SUMMARY_RENDER_SCALE=1
# Keep false to preserve Google Sheet column layout in output image.
# Set true to auto-resize columns based on text width.
WF21_SUMMARY_AUTO_FIT_COLUMNS=false
# Used only when WF21_SUMMARY_RENDER_MODE=pdf_png
# Requires either pdftoppm (Poppler) or magick (ImageMagick)
WF21_SUMMARY_PDF_DPI=180
WF21_SUMMARY_PDF_CONVERTER=auto
WF21_SUMMARY_IMAGE_MAX_WIDTH_PX=1800
WF21_SUMMARY_IMAGE_MAX_BASE64_BYTES=2097152
WF21_SUMMARY_HTTP_TIMEOUT_SECONDS=90
WF21_TIMEZONE=Asia/Manila
