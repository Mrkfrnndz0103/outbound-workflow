PORT=8080

# Modes:
# - bot: callback-driven bot commands/events
# - system_account: outbound-only group messaging via system account webhook
SEATALK_MODE=bot

# Bot mode config (SEATALK_MODE=bot)
SEATALK_SIGNING_SECRET=
SEATALK_APP_ID=
SEATALK_APP_SECRET=
SEATALK_BASE_URL=https://openapi.seatalk.io

# System account mode config (SEATALK_MODE=system_account)
SEATALK_SYSTEM_WEBHOOK_URL=

SEATALK_HTTP_TIMEOUT_SECONDS=10

BOT_COMMAND_PREFIX=/
WORKFLOWS_FILE=workflows.yaml
WORKFLOW_DEFAULT_TIMEOUT_SECONDS=120

# Workflow 1 (MM LH Provided -> SeaTalk trigger)
WF1_GOOGLE_CREDENTIALS_FILE=
# Alternative to credentials file (full JSON string)
WF1_GOOGLE_CREDENTIALS_JSON=
# WF1_SHEET_ID defaults to 1mhzIfYfF1VSA9sPiqnLw7OgY1S_gI0wEzkXBQ1CCuDg
WF1_SHEET_ID=
# WF1_SHEET_TAB defaults to "MM LH Provided"
WF1_SHEET_TAB=
# WF1_SHEET_RANGE defaults to "A2:M"
WF1_SHEET_RANGE=
# State file that stores last seen Plate # per row
WF1_STATE_FILE=data/workflow1-mm-lh-provided-state.json
# Runtime status output file (set to "none" to disable)
WF1_STATUS_FILE=data/workflow1-mm-lh-provided-status.json
# false = first run baselines current rows and does not send existing non-blank Plate # rows
WF1_BOOTSTRAP_SEND_EXISTING=false
WF1_AT_ALL=false
WF1_DRY_RUN=false
WF1_DEBUG_LOG_SKIPS=false
WF1_HTTP_TIMEOUT_SECONDS=10
WF1_CONTINUOUS=false
WF1_POLL_INTERVAL_SECONDS=10
WF1_FORCE_SEND_AFTER_SECONDS=300
# Hold a ready row briefly to allow same-minute Provide Time rows to merge
WF1_GROUP_DEFER_SECONDS=20
# Outbound throttle/retry to avoid SeaTalk rate limits (429 code=8)
WF1_SEND_MIN_INTERVAL_MS=1200
WF1_SEND_RETRY_MAX_ATTEMPTS=5
WF1_SEND_RETRY_BASE_MS=1000
WF1_SEND_RETRY_MAX_MS=30000
# Optional health server + self-ping (useful on Render web services)
WF1_ENABLE_HEALTH_SERVER=false
WF1_HEALTH_PORT=
WF1_SELF_PING_URL=
WF1_SELF_PING_INTERVAL_SECONDS=300
